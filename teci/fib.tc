let a = 0;
let count = 0;
let temp;
for (let b = 1; a < 10000; b = temp + b) {
    print "Fib(" + count + ") = " + a;
    count = count + 1;
    temp = a;
    a = b;

    if (a > 1000) {
        break;
    }
}

print "";

fun fib_rec(n) {
    if (n <= 1) {
        return n;
    }
    return fib_rec(n - 1) + fib_rec(n - 2);
}

for (let i = 0; i <= 20; i = i + 1) {
    print "Fib(" + i + ") = " + fib_rec(i);
}
